# Lisa Smart Home Configuration
# Copy to .env and edit values

# Development mode (true = use fake device adapter)
LISA_DEV_MODE=true

# SQLite database path
LISA_DB_PATH=lisa.db

# Backend server
LISA_HOST=0.0.0.0
LISA_PORT=8001

# TP-Link Kasa credentials (required for newer devices)
# Leave empty if your devices do not require authentication
LISA_KASA_USERNAME=
LISA_KASA_PASSWORD=

# Voice Pipeline (Phase 2)
LISA_OPENAI_API_KEY=           # OpenAI API key for Whisper STT
LISA_ANTHROPIC_API_KEY=        # Anthropic API key for Claude LLM intent parsing
LISA_STT_MODEL=whisper-1       # STT model
LISA_STT_TIMEOUT=3.0           # STT timeout in seconds
LISA_LLM_MODEL=claude-haiku-4-5  # LLM model for intent parsing
LISA_LLM_TIMEOUT=3.0           # LLM timeout in seconds
LISA_TTS_MODEL_PATH=           # Path to Piper .onnx voice model file
LISA_TTS_OUTPUT_DIR=tts_output # Dev mode: directory for TTS WAV output
